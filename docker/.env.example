# Copier ce fichier en ".env" (à côté de docker-compose.yml) et renseigner
# de vraies valeurs. Ne JAMAIS committer le fichier ".env" réel.

# --- Base de données ---
POSTGRES_DB=proofpay
POSTGRES_USER=proofpay
POSTGRES_PASSWORD=change-me

# --- Backend ---
# local en dev, prod en production (voir application-prod.yml)
SPRING_PROFILES_ACTIVE=local
# Générer avec: openssl rand -base64 48
JWT_SECRET=change-me-32-chars-minimum-generated-randomly
PROOFPAY_CORS_ORIGINS=http://localhost:4200
JAVA_OPTS=-Xmx512m -Xms256m
# Numéro(s) promus automatiquement en ADMIN à leur prochaine connexion OTP.
# Nécessaire pour scripts/smoke-test.sh et pour créer le premier compte admin.
PROOFPAY_ADMIN_PHONES=+22890000099
